{
  "name": "@hackclub/icons",
  "version": "0.1.0",
  "description": "Hack Club’s iconset, a superset of spectrum-icons",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "icon",
    "react"
  ],
  "author": "Lachlan Campbell <lachlan@hackclub.com>",
  "scripts": {
    "build": "yarn prepare && yarn docs:build",
    "dev": "yarn docs:dev",
    "docs:build": "yarn --cwd docs build",
    "docs:dev": "yarn --cwd docs dev",
    "docs:start": "yarn --cwd docs start",
    "prepare": "tsc && babel src --extensions .tsx --out-dir dist --presets @babel/env,@babel/react,@babel/typescript && babel src --extensions .tsx --out-dir dist/esm --presets @babel/react,@babel/typescript && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "test": "node scripts/test-icons.js"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@hackclub/theme": "^1.0.0",
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.14",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackclub/icons.git"
  },
  "bugs": {
    "url": "https://github.com/hackclub/icons/issues"
  },
  "homepage": "https://icons.hackclub.com"
}
